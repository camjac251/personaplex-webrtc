# PersonaPlex Environment Variables
# Copy this file to .env and fill in your values.

# REQUIRED: HuggingFace read token.
# Create one at https://huggingface.co/settings/tokens and accept the model
# license for the checkpoint you plan to run.
HF_TOKEN=hf_your_token_here

# OPTIONAL: Gemini API key. Set it to enable the vision features; leave empty
# to run voice-only.
GEMINI_API_KEY=

# OPTIONAL: checkpoint selection. "rl-seamless" (default) is the
# interactivity-aligned RL checkpoint; "base" selects the NVIDIA rollback.
PERSONAPLEX_MODEL=rl-seamless

# OPTIONAL: custom HuggingFace repo to load instead of the built-in pins.
# When set, PERSONAPLEX_HF_REVISION is required.
PERSONAPLEX_HF_REPO=

# OPTIONAL: pinned revision (commit SHA) for PERSONAPLEX_HF_REPO.
# Required whenever PERSONAPLEX_HF_REPO is set.
PERSONAPLEX_HF_REVISION=

# OPTIONAL: periodic full-state snapshots for long-session auto-rewind.
# Enabled by default; set to 0 to disable or 1 to force on. Empty keeps the
# default.
PERSONAPLEX_PERIODIC_SNAPSHOTS=

# OPTIONAL: comma-separated STUN URLs for WebRTC ICE negotiation. Leave empty
# for fully-direct connectivity (LAN or a host with open UDP).
WEBRTC_STUN_URLS=
